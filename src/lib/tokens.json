      "fade-in": {
        "value": "{ opacity: 0; } to { opacity: 1; }",
        "type": "keyframe"
      },
      "scale-in": {
        "value": "{ opacity: 0; transform: scale(0.94); } to { opacity: 1; transform: scale(1); }",
        "type": "keyframe"
      },
      "slide-down": {
        "value": "{ opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); }",
        "type": "keyframe"
      },
      "slide-in-right": {
        "value": "{ opacity: 0; transform: translateX(40px); } to { opacity: 1; transform: translateX(0); }",
        "type": "keyframe"
      },
      "float": {
        "value": "0%, 100% { transform: translateY(0); } 50% { transform: translateY(-12px); }",
        "type": "keyframe"
      },
      "pulse-glow": {
        "value": "0%, 100% { box-shadow: 0 0 20px rgba(124, 58, 237, 0.3); } 50% { box-shadow: 0 0 40px rgba(124, 58, 237, 0.6); }",
        "type": "keyframe"
      },
      "spin-slow": {
        "value": "from { transform: rotate(0deg); } to { transform: rotate(360deg); }",
